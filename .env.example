# ============================================
# Database
# ============================================
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=qltd_db
MYSQL_USER=qltd_user
MYSQL_PASSWORD=change_me_db_password

# ============================================
# App secrets
# ============================================
# Keep API/OAuth/SMTP/Firebase app keys in:
#   config/application-local.properties
# This file is mounted read-only into the container at /app/config/application-local.properties

# ============================================
# Domain (for Nginx & OAuth redirect)
# ============================================
DOMAIN=your-domain.com
APP_PUBLIC_BASE_URL=https://your-domain.com

# ============================================
# Production bootstrap
# ============================================
APP_DEFAULT_ADMIN_EMAIL=admin@your-domain.com
APP_DEFAULT_ADMIN_PASSWORD=change_me_admin_password
APP_DEFAULT_ADMIN_FULL_NAME=Production Admin
APP_DEFAULT_ADMIN_PHONE=0900000000
APP_SEED_DEMO_DATA=false
